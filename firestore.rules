rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CleanOps Hub Multi-Tenant Master Control Rules
     * 
     * Hierarchy: /userProfiles/{userProfileId}
     * Master Users: clean@flow.com or clean@flow.co.uk
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'clean@flow.com' || 
        request.auth.token.email == 'clean@flow.co.uk'
      );
    }

    function isMember(userProfileId) {
      // Primary check: Is this the user's default personal hub?
      if (userProfileId == 'hub-' + request.auth.uid) {
        return true;
      }
      // Secondary check: Are they explicitly in the members map?
      // Note: get() calls in rules are fine for path-bound subcollection queries
      let profile = get(/databases/$(database)/documents/userProfiles/$(userProfileId)).data;
      return isSignedIn() && (request.auth.uid in profile.members || isMaster());
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      allow read, list: if isSignedIn() && (
        request.auth.uid in resource.data.members || 
        isMaster() || 
        userProfileId == 'hub-' + request.auth.uid
      );
      
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        resource.data.members[request.auth.uid] == 'owner' || 
        isMaster() || 
        userProfileId == 'hub-' + request.auth.uid
      );
      allow delete: if isMaster();
    }

    // Subcollections follow the hub membership, identity check, or master control
    match /userProfiles/{userProfileId}/sites/{siteId} {
      allow read, write: if isSignedIn() && (
        userProfileId == 'hub-' + request.auth.uid || 
        isMaster() || 
        isMember(userProfileId)
      );
    }

    match /userProfiles/{userProfileId}/cleaners/{cleanerId} {
      allow read, write: if isSignedIn() && (
        userProfileId == 'hub-' + request.auth.uid || 
        isMaster() || 
        isMember(userProfileId)
      );
    }

    match /userProfiles/{userProfileId}/cleaningScheduleEntries/{scheduleEntryId} {
      allow read, write: if isSignedIn() && (
        userProfileId == 'hub-' + request.auth.uid || 
        isMaster() || 
        isMember(userProfileId)
      );
    }
    
    // Fallback for master control across all paths
    match /{path=**} {
      allow read, write: if isMaster();
    }
  }
}