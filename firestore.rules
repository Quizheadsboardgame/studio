
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'clean@flow.com' || 
        request.auth.token.email == 'clean@flow.co.uk'
      );
    }

    // --- User Profiles (Hubs) ---
    match /userProfiles/{userProfileId} {
      // Allow Master to do anything with profiles
      allow read, write: if isMaster();

      // Allow users to list profiles they are a member of
      allow list: if isSignedIn() && (
        userProfileId == 'hub-' + request.auth.uid || 
        request.auth.uid in resource.data.members
      );

      // Single document access
      allow get: if isSignedIn() && (
        userProfileId == 'hub-' + request.auth.uid || 
        request.auth.uid in resource.data.members
      );
      
      // Allow creation during sign-up
      allow create: if isSignedIn(); 
      
      // Allow owners to update their own hub (e.g. adding members)
      allow update: if isSignedIn() && (
        userProfileId == 'hub-' + request.auth.uid || 
        resource.data.members[request.auth.uid] == 'owner'
      );

      // --- Hub-Scoped Data (Subcollections) ---
      match /{collectionName}/{docId} {
        allow read, write: if isMaster();
        
        allow list, get: if isSignedIn() && (
          userProfileId == 'hub-' + request.auth.uid || 
          get(/databases/$(database)/documents/userProfiles/$(userProfileId)).data.members[request.auth.uid] != null
        );

        allow create, update, delete: if isSignedIn() && (
          userProfileId == 'hub-' + request.auth.uid || 
          get(/databases/$(database)/documents/userProfiles/$(userProfileId)).data.members[request.auth.uid] in ['owner', 'admin']
        );
      }
    }
    
    // Universal Master Fallback
    match /{path=**} {
      allow read, write: if isMaster();
    }
  }
}
