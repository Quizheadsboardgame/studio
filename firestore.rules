rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow public access to all collections as login was removed
    // and all sensitive client contact details have been deleted.
    
    match /sites/{siteId} {
      allow read, write: if true;
      match /consumables/{consumableId} {
        allow read, write: if true;
      }
    }
    
    match /cleaners/{cleanerId} {
      allow read, write: if true;
    }
    
    match /actionPlans/{planId} {
      allow read, write: if true;
    }
    
    match /leave/{leaveId} {
      allow read, write: if true;
    }
    
    match /schedule/{entryId} {
      allow read, write: if true;
    }
    
    match /supplyOrders/{orderId} {
      allow read, write: if true;
    }
    
    match /monthlyAudits/{auditId} {
      allow read, write: if true;
    }
    
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }
    
    match /tasks/{taskId} {
      allow read, write: if true;
    }
    
    match /conversationRecords/{recordId} {
      allow read, write: if true;
    }
    
    match /goodNewsRecords/{recordId} {
      allow read, write: if true;
    }

    // Fallback for any other nested documents
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
