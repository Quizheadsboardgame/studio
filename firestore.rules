rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CleanOps Hub Multi-Tenant Master Control Rules
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'clean@flow.com' || 
        request.auth.token.email == 'clean@flow.co.uk'
      );
    }

    // --- User Profiles (Hubs) ---
    match /userProfiles/{userProfileId} {
      // Split list rules to ensure Master users can list all docs unconditionally
      allow list: if isMaster();
      allow list: if isSignedIn() && (
        userProfileId == 'hub-' + request.auth.uid || 
        request.auth.uid in resource.data.members
      );

      // Single document access
      allow get: if isSignedIn() && (
        isMaster() || 
        userProfileId == 'hub-' + request.auth.uid || 
        request.auth.uid in resource.data.members
      );
      
      allow create: if isSignedIn(); 
      
      allow update: if isSignedIn() && (
        isMaster() || 
        userProfileId == 'hub-' + request.auth.uid || 
        resource.data.members[request.auth.uid] == 'owner'
      );
      
      allow delete: if isMaster();

      // --- Hub-Scoped Data (Subcollections) ---
      // We use denormalized members map in documents for efficient listing
      match /{collectionName}/{docId} {
        allow list: if isMaster();
        allow list: if isSignedIn() && (
          userProfileId == 'hub-' + request.auth.uid || 
          request.auth.uid in resource.data.members
        );

        allow get: if isSignedIn() && (
          isMaster() || 
          userProfileId == 'hub-' + request.auth.uid || 
          request.auth.uid in resource.data.members
        );

        allow create: if isSignedIn() && (
          isMaster() || 
          userProfileId == 'hub-' + request.auth.uid ||
          get(/databases/$(database)/documents/userProfiles/$(userProfileId)).data.members[request.auth.uid] != null
        );

        allow update, delete: if isSignedIn() && (
          isMaster() || 
          userProfileId == 'hub-' + request.auth.uid || 
          request.auth.uid in resource.data.members
        );
      }
    }
    
    // Universal Master Fallback
    match /{path=**} {
      allow read, write: if isMaster();
    }
  }
}