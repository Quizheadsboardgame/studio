rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CleanOps Hub Multi-Tenant Master Control Rules
     * 
     * Hierarchy: /userProfiles/{userProfileId}
     * Master User: clean@flow.com (UID check required)
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Replace this UID with the actual UID of clean@flow.com after registration
    // For now, we allow owners and admins within hubs.
    function isMaster() {
      return isSignedIn() && request.auth.token.email == 'clean@flow.com';
    }

    function isMember(userProfileId) {
      let profile = get(/databases/$(database)/documents/userProfiles/$(userProfileId)).data;
      return isSignedIn() && (request.auth.uid in profile.members || isMaster());
    }

    function isAtLeastAdmin(userProfileId) {
      let profile = get(/databases/$(database)/documents/userProfiles/$(userProfileId)).data;
      return isSignedIn() && (profile.members[request.auth.uid] in ['owner', 'admin'] || isMaster());
    }

    // --- Collection Rules ---

    match /userProfiles/{userProfileId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.members || isMaster());
      allow list: if isSignedIn() && (request.auth.uid in resource.data.members || isMaster());
      
      allow create: if isSignedIn(); // User can create their own profile or master can create
      allow update: if isSignedIn() && (resource.data.members[request.auth.uid] == 'owner' || isMaster());
      allow delete: if isMaster();
    }

    // Subcollections follow the hub membership or master control
    match /userProfiles/{userProfileId}/sites/{siteId} {
      allow read, write: if isMember(userProfileId);
    }

    match /userProfiles/{userProfileId}/cleaners/{cleanerId} {
      allow read, write: if isMember(userProfileId);
    }

    match /userProfiles/{userProfileId}/cleaningScheduleEntries/{scheduleEntryId} {
      allow read, write: if isMember(userProfileId);
    }
    
    // Fallback for unexpected paths during development
    match /{path=**} {
      allow read, write: if isMaster();
    }
  }
}
